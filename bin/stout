#!/usr/bin/env php
<?php

declare(strict_types=1);

$basePath = null;

if (file_exists(__DIR__ . '/../vendor/autoload.php')) {
    $basePath = dirname(__DIR__);
} elseif (file_exists(__DIR__ . '/../../../../vendor/autoload.php')) {
    $basePath = dirname(__DIR__, 4);
} elseif (file_exists(__DIR__ . '/../../vendor/autoload.php')) {
    $basePath = dirname(__DIR__, 2);
} else {
    $basePath = getcwd();
}

if ($basePath !== false && is_dir($basePath)) {
    chdir($basePath);
}

$projectAutoloader = $basePath . '/vendor/autoload.php';
$frameworkAutoloader = __DIR__ . '/../vendor/autoload.php';

if (file_exists($projectAutoloader)) {
    require $projectAutoloader;
} elseif (file_exists($frameworkAutoloader)) {
    require $frameworkAutoloader;
} else {
    fwrite(STDERR, "Error: composer dependencies are not installed. Run 'composer install' first.\n");
    exit(1);
}

use Stout\Application;

$bootstrapFile = $basePath . '/bootstrap/app.php';
if (file_exists($bootstrapFile)) {
    /** @var Application $app */
    $app = require $bootstrapFile;
} else {
    $app = new Application($basePath);
}

$exitCode = $app->runCli($argv);

exit($exitCode);

