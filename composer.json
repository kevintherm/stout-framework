{
    "name": "stout/stout",
    "description": "Lightweight opinionated PHP framework built on Slim with strict types, PHP-DI, and RoadRunner.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "framework",
        "slim",
        "php-di",
        "roadrunner",
        "stout"
    ],
    "authors": [
        {
            "name": "Kevin",
            "email": "kevindrm0@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "php-di/php-di": "^7.0",
        "slim/http": "^1.4",
        "slim/psr7": "^1.7",
        "slim/slim": "^4.14",
        "spiral/roadrunner-cli": "^2.6",
        "spiral/roadrunner-http": "^3.4",
        "spiral/roadrunner-worker": "^3.5",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Stout\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Stout\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/stout"
    ],
    "scripts": {
        "test": "pest --colors=always",
        "test:coverage": "pest --coverage --colors=always",
        "analyse": "phpstan analyse --ansi --memory-limit=-1"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}